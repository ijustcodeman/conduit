// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model Article {
  id           Int     @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String
  body        String
  tags        Tag[]
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String    @unique

  articles Article[]
}

model User {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  email     String  @unique
  password  String
}
